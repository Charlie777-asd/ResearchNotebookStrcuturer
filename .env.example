# ── ResearchAI Environment Configuration ─────────────────────────
# Copy this file to .env and fill in your Gemini API key.

# Google Gemini API Key (Required for AI generation, structuring, and suggestions)
# Obtain your key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
PORT=5050
HOST=0.0.0.0
FLASK_ENV=development
